{'Makefile': 'CXX ?= g++\n\n# Try to derive Legion_DIR from LEGION_ROOT if not provided explicitly.\nLEGION_DIR ?= $(if $(LEGION_ROOT),$(LEGION_ROOT)/lib/cmake/Legion,)\n\n# Resolve Legion compile/link flags via CMake package discovery (preferred).\nLEGION_CFLAGS := $(strip $(shell if [ -n "$(Legion_DIR)" ]; then cmake --find-package -DNAME=Legion -DCOMPILER_ID=GNU -DLANGUAGE=CXX -DMODE=COMPILE -DLegion_DIR=$(Legion_DIR) 2>/dev/null | tr \';\' \' \'; fi))\nLEGION_LIBS   := $(strip $(shell if [ -n "$(Legion_DIR)" ]; then cmake --find-package -DNAME=Legion -DCOMPILER_ID=GNU -DLANGUAGE=CXX -DMODE=LINK    -DLegion_DIR=$(Legion_DIR) 2>/dev/null | tr \';\' \' \'; fi))\n\n# Fallback to pkg-config if CMake package discovery is unavailable.\nifeq ($(strip $(LEGION_CFLAGS)),)\nLEGION_CFLAGS := $(strip $(shell pkg-config --cflags legion 2>/dev/null))\nendif\n\nifeq ($(strip $(LEGION_LIBS)),)\nLEGION_LIBS := $(strip $(shell pkg-config --libs legion 2>/dev/null))\nendif\n\n# Final fallback using LEGION_ROOT/system defaults.\nifeq ($(strip $(LEGION_CFLAGS)),)\nifneq ($(strip $(LEGION_ROOT)),)\nLEGION_CFLAGS := -I$(LEGION_ROOT)/include -I$(LEGION_ROOT)/include/legion\nendif\nendif\n\nifeq ($(strip $(LEGION_LIBS)),)\nifneq ($(strip $(LEGION_ROOT)),)\nLEGION_LIBS := -L$(LEGION_ROOT)/lib -Wl,-rpath,$(LEGION_ROOT)/lib -llegion\nelse\nLEGION_LIBS := -llegion\nendif\nendif\n\n# Boost paths (optional)\nifneq ($(strip $(BOOST_ROOT)),)\nBOOST_INCLUDE := -I$(BOOST_ROOT)/include\nBOOST_LIB     := -L$(BOOST_ROOT)/lib -Wl,-rpath,$(BOOST_ROOT)/lib\nendif\n\nCXXFLAGS += -std=c++17 -I. -g -DASTM_LEGION -pthread $(LEGION_CFLAGS) $(BOOST_INCLUDE)\nLDFLAGS  += -pthread $(LEGION_LIBS) $(BOOST_LIB)\n\nADDITIONAL_SOURCES =\nPROGRAMS = build/binary_tree build/unit_tests build/concurrency_tests\nDIRECTORIES = build\n\nall: directories $(PROGRAMS)\n\n.PHONY: all clean directories\n\ndirectories: $(DIRECTORIES)/\n\n$(DIRECTORIES)/:\n\tmkdir -p $@\n\nbuild/%: %.cpp | $(DIRECTORIES)/\n\t$(CXX) $(CXXFLAGS) $(ADDITIONAL_SOURCES) $< -o $@ $(LDFLAGS)\n\nclean:\n\trm -rf $(DIRECTORIES)\n', 'ReadMe.md': '# ASTM (Asynchronous Software Transaction Memory)\n\nA header-only Software Transactional Memory (STM) library built on Legion. ASTM provides optimistic concurrency control for shared variables and features such as:\n\nTransaction manager:\n    - Provides transaction-local storage\n    - Implement the four basic operations which occur in transactions: read, write, async, commit \n\n## Programs\nbinary_tree\nExample implementation of an unbalanced binary tree implemented using ASTM, with values that have side-effecting constructors. Each non-empty node has astm::new to allocate its value so there are no dependencies, and abstracts programmers away from performing explicit reads and writes through the use of smart pointer syntax. Results are written to binary_tree.txt.\n\nunit_tests\nUnit tests covering core STM operations: read/write ordering, overwrites, arithmetic with local variables, future-based reads, and transaction retry logic on conflict. Results are written to unit_tests.txt.\n\nconcurrency_tests\nConcurrency stress tests verifying atomicity under contention, including threads incrementing a shared integer and squaring transactions. Results are written to concurrency_test.txt. \n\n## Prerequisites \n\n- Legion installed\n- A C++17-compliant C++ compiler (e.g. GCC, Clang) and beyond\n- Boost, which path is set as `BOOST_ROOT` and incorporated into `LD_LIBRARY_PATH`\n\n### Build\n-----------------\nRepository depends on Legion 25.06.0\n\nMake sure to set $LEGION_ROOT to Legion install directory \n', 'astm.hpp': '////////////////////////////////////////////////////////////////////////////////\n//  Copyright (c) 2014 Bryce Adelstein-Lelbach\n//  Copyright (c) 2014 Steve Brandt\n//\n//  Distributed under the Boost Software License, Version 1.0. (See accompanying\n//  file LICENSE_1_0.txt or copy at http://www.boost.org/LICENSE_1_0.txt)\n////////////////////////////////////////////////////////////////////////////////\n\n#if !defined(ASTM_DBA88345_57B8_4CC8_A574_D5F007250E94)\n#define ASTM_DBA88345_57B8_4CC8_A574_D5F007250E94\n\n#include "astm_config.hpp"\n\n#include <legion.h>\n\n#include <atomic>\n#include <cassert>\n#include <cstdint>\n#include <functional>\n#include <list>\n#include <map>\n#include <memory>\n#include <mutex>\n#include <set>\n#include <unordered_map>\n#include <utility>\n#include <vector>\n\nnamespace astm\n{\n\nstruct transaction;\n\n// ----------------------------------------------------------------------------\n// Legion context binding helpers.\n// Call bind_legion_context(runtime, ctx) at the beginning of a Legion task\n// before using ASTM transactional async continuations.\n// ----------------------------------------------------------------------------\nnamespace detail\n{\n    constexpr Legion::TaskID ASTM_INTERNAL_CONTINUATION_TASK_ID = 0xAC710001;\n\n    struct continuation_payload\n    {\n        std::uint64_t callback_id;\n        std::uintptr_t transaction_ptr;\n    };\n\n    inline thread_local Legion::Runtime* tls_runtime = nullptr;\n    inline thread_local Legion::Context tls_context = Legion::Context();\n    inline thread_local bool tls_bound = false;\n\n    inline std::mutex& callback_mutex()\n    {\n        static std::mutex m;\n        return m;\n    }\n\n    inline std::unordered_map<std::uint64_t, std::function<void(transaction*)>>& callback_table()\n    {\n        static std::unordered_map<std::uint64_t, std::function<void(transaction*)>> table;\n        return table;\n    }\n\n    inline std::atomic<std::uint64_t>& next_callback_id()\n    {\n        static std::atomic<std::uint64_t> id{1};\n        return id;\n    }\n\n    inline void bind_context(Legion::Runtime* runtime, Legion::Context context)\n    {\n        tls_runtime = runtime;\n        tls_context = context;\n        tls_bound = (runtime != nullptr);\n    }\n\n    inline void unbind_context()\n    {\n        tls_runtime = nullptr;\n        tls_context = Legion::Context();\n        tls_bound = false;\n    }\n\n    inline bool has_bound_context()\n    {\n        return tls_bound;\n    }\n\n    inline void continuation_task(\n        Legion::Task const* task,\n        std::vector<Legion::PhysicalRegion> const&,\n        Legion::Context,\n        Legion::Runtime*)\n    {\n        assert(task != nullptr);\n        assert(task->arglen == sizeof(continuation_payload));\n\n        continuation_payload payload =\n            *reinterpret_cast<continuation_payload const*>(task->args);\n\n        std::function<void(transaction*)> fn;\n        {\n            std::lock_guard<std::mutex> l(callback_mutex());\n            auto& table = callback_table();\n            auto it = table.find(payload.callback_id);\n            if (it != table.end())\n            {\n                fn = std::move(it->second);\n                table.erase(it);\n            }\n        }\n\n        if (fn)\n            fn(reinterpret_cast<transaction*>(payload.transaction_ptr));\n    }\n\n    inline void preregister_internal_tasks()\n    {\n        static std::once_flag once;\n        std::call_once(once, [] {\n            Legion::TaskVariantRegistrar registrar(\n                ASTM_INTERNAL_CONTINUATION_TASK_ID,\n                "astm_internal_continuation_task");\n            registrar.add_constraint(\n                Legion::ProcessorConstraint(Legion::Processor::LOC_PROC));\n            registrar.set_leaf();\n\n            Legion::Runtime::preregister_task_variant<continuation_task>(\n                registrar, "astm_internal_continuation_task");\n        });\n    }\n\n    inline Legion::Future launch_continuation(\n        std::function<void(transaction*)> fn,\n        transaction* trans,\n        Legion::Future const& dependency = Legion::Future())\n    {\n        assert(has_bound_context() &&\n               "ASTM Legion context not bound. Call astm::bind_legion_context "\n               "inside the current Legion task first.");\n        assert(trans != nullptr);\n\n        preregister_internal_tasks();\n\n        std::uint64_t id = next_callback_id().fetch_add(1, std::memory_order_relaxed);\n        {\n            std::lock_guard<std::mutex> l(callback_mutex());\n            callback_table().emplace(id, std::move(fn));\n        }\n\n        continuation_payload payload{id, reinterpret_cast<std::uintptr_t>(trans)};\n        Legion::TaskLauncher launcher(\n            ASTM_INTERNAL_CONTINUATION_TASK_ID,\n            Legion::TaskArgument(&payload, sizeof(payload)));\n\n        // Keep execution local to the current address space; default mapper handles placement.\n        launcher.map_locally = true;\n\n        if (dependency.exists())\n            launcher.add_future(dependency);\n\n        return tls_runtime->execute_task(tls_context, launcher);\n    }\n} // namespace detail\n\ninline void bind_legion_context(Legion::Runtime* runtime, Legion::Context context)\n{\n    detail::bind_context(runtime, context);\n    detail::preregister_internal_tasks();\n}\n\ninline void unbind_legion_context()\n{\n    detail::unbind_context();\n}\n\nstruct legion_context_scope\n{\n    legion_context_scope(Legion::Runtime* runtime, Legion::Context context)\n    {\n        bind_legion_context(runtime, context);\n    }\n\n    ~legion_context_scope()\n    {\n        unbind_legion_context();\n    }\n};\n\n// Force preregistration in any TU that includes this header before Runtime::start.\ninline const bool astm_legion_preregistered = [] {\n    detail::preregister_internal_tasks();\n    return true;\n}();\n\n// ----------------------------------------------------------------------------\n// STM core\n// ----------------------------------------------------------------------------\nstruct shared_var_base\n{\n    virtual ~shared_var_base() {}\n\n    virtual shared_var_base* clone() const = 0;\n    virtual void write(shared_var_base const&) = 0;\n    virtual ASTM_LOCK lock() const = 0;\n    virtual bool operator==(shared_var_base const&) const = 0;\n};\n\nstruct transaction_future\n{\n    using future_type = Legion::Future;\n\n  private:\n    transaction* trans_;\n    future_type fut_;\n\n  public:\n    explicit transaction_future(transaction* trans)\n      : trans_(trans)\n      , fut_()\n    {}\n\n    explicit transaction_future(transaction& trans)\n      : trans_(&trans)\n      , fut_()\n    {}\n\n    template <typename F>\n    void then(F f);\n\n    void get()\n    {\n        if (fut_.exists())\n            fut_.get_void_result();\n    }\n};\n\ntemplate <typename T>\nstruct shared_var : shared_var_base\n{\n    using future_type = Legion::Future;\n\n    struct local_var\n    {\n      private:\n        transaction* trans_;\n        shared_var_base* var_;\n\n      public:\n        local_var(transaction* trans, shared_var_base* var)\n          : trans_(trans)\n          , var_(var)\n        {}\n\n        T get() const;\n        operator T const&() const;\n        local_var& operator=(shared_var_base const& rhs);\n        local_var& operator=(T const& rhs);\n\n        template <typename F>\n        void then(F f);\n    };\n\n  private:\n    T data_;\n    mutable ASTM_MUTEX mtx_;\n\n  public:\n    future_type queue;\n\n    shared_var() : data_(), mtx_(), queue() {}\n    explicit shared_var(T const& t) : data_(t), mtx_(), queue() {}\n    explicit shared_var(T&& t) : data_(std::move(t)), mtx_(), queue() {}\n    shared_var(shared_var const& rhs) : data_(rhs.data_), mtx_(), queue() {}\n    ~shared_var() {}\n\n    shared_var_base* clone() const override\n    {\n        auto l = lock();\n        (void)l;\n        return new shared_var(data_);\n    }\n\n    T const& read() const\n    {\n        return data_;\n    }\n\n    void write(T const& rhs)\n    {\n        data_ = rhs;\n    }\n\n    void write(shared_var_base const& rhs) override\n    {\n        auto const* typed = dynamic_cast<shared_var const*>(&rhs);\n        assert(typed != nullptr);\n        data_ = typed->read();\n    }\n\n    ASTM_LOCK lock() const override\n    {\n        return ASTM_LOCK(mtx_);\n    }\n\n    bool operator==(shared_var_base const& rhs) const override\n    {\n        auto const* typed = dynamic_cast<shared_var const*>(&rhs);\n        assert(typed != nullptr);\n        return data_ == typed->read();\n    }\n\n    local_var get_local(transaction& trans)\n    {\n        return local_var(&trans, this);\n    }\n};\n\nstruct transaction\n{\n    std::list<\n        std::pair<\n            shared_var_base*,\n            std::shared_ptr<shared_var_base>>> read_list;\n\n    std::set<shared_var_base*> write_set;\n\n    std::list<\n        std::pair<\n            Legion::Future*,\n            std::function<void(transaction*)>>> async_list;\n\n    std::map<\n        shared_var_base*,\n        std::shared_ptr<shared_var_base>> variables;\n\n    void clear()\n    {\n        read_list.clear();\n        write_set.clear();\n        async_list.clear();\n        variables.clear();\n    }\n\n    bool commit_transaction()\n    {\n        std::list<ASTM_LOCK> locks;\n\n        for (auto const& var : variables)\n        {\n            assert(var.first != nullptr);\n            locks.push_back(var.first->lock());\n        }\n\n        for (auto const& var : read_list)\n        {\n            assert(var.first != nullptr);\n            if (!((*var.first) == (*var.second)))\n            {\n                clear();\n                return false;\n            }\n        }\n\n        for (shared_var_base* var : write_set)\n        {\n            assert(var != nullptr);\n            auto it = variables.find(var);\n            assert(it != variables.end());\n            var->write(*it->second);\n        }\n\n        // Legion-backed continuations (default mapper, no custom mapping).\n        for (auto& op : async_list)\n        {\n            if (op.first == nullptr)\n            {\n                (void)detail::launch_continuation(op.second, this);\n            }\n            else\n            {\n                *op.first = detail::launch_continuation(op.second, this, *op.first);\n            }\n        }\n\n        return true;\n    }\n\n    shared_var_base const& read(shared_var_base* var)\n    {\n        assert(var != nullptr);\n\n        std::pair<shared_var_base*, std::shared_ptr<shared_var_base>> entry(var, nullptr);\n        auto result = variables.insert(entry);\n\n        if (result.second)\n        {\n            result.first->second.reset(var->clone());\n            read_list.push_back(*result.first);\n            return *(result.first->second);\n        }\n\n        return *(result.first->second);\n    }\n\n    void write(shared_var_base* var, shared_var_base const& value)\n    {\n        assert(var != nullptr);\n\n        std::pair<shared_var_base*, std::shared_ptr<shared_var_base>> entry(\n            var, std::shared_ptr<shared_var_base>(value.clone()));\n\n        auto result = variables.insert(entry);\n\n        if (result.second)\n        {\n            write_set.insert(var);\n        }\n        else\n        {\n            result.first->second = entry.second;\n            write_set.insert(var);\n        }\n    }\n\n    void then(Legion::Future* fut, std::function<void(transaction*)> F)\n    {\n        async_list.emplace_back(fut, std::move(F));\n    }\n};\n\ntemplate <typename T>\nshared_var<T>::local_var::operator T const&() const\n{\n    auto const* typed = dynamic_cast<shared_var const*>(&trans_->read(var_));\n    assert(typed != nullptr);\n    return typed->read();\n}\n\ntemplate <typename T>\nT shared_var<T>::local_var::get() const\n{\n    auto const* typed = dynamic_cast<shared_var const*>(&trans_->read(var_));\n    assert(typed != nullptr);\n    return typed->read();\n}\n\ntemplate <typename T>\ntypename shared_var<T>::local_var&\nshared_var<T>::local_var::operator=(shared_var_base const& rhs)\n{\n    trans_->write(var_, rhs);\n    return *this;\n}\n\ntemplate <typename T>\ntypename shared_var<T>::local_var&\nshared_var<T>::local_var::operator=(T const& rhs)\n{\n    shared_var tmp(rhs);\n    trans_->write(var_, tmp);\n    return *this;\n}\n\ntemplate <typename T>\ntemplate <typename F>\nvoid shared_var<T>::local_var::then(F f)\n{\n    assert(trans_ != nullptr);\n    auto* typed = dynamic_cast<shared_var*>(var_);\n    assert(typed != nullptr);\n    trans_->then(&typed->queue, std::function<void(transaction*)>(f));\n}\n\ntemplate <typename F>\nvoid transaction_future::then(F f)\n{\n    assert(trans_ != nullptr);\n    trans_->then(&fut_, std::function<void(transaction*)>(f));\n}\n\n} // namespace astm\n\n#endif // ASTM_DBA88345_57B8_4CC8_A574_D5F007250E94\n', 'astm_config.hpp': '////////////////////////////////////////////////////////////////////////////////\n//  Copyright (c) 2014 Bryce Adelstein-Lelbach\n//  Copyright (c) 2014 Steve Brandt\n//\n//  Distributed under the Boost Software License, Version 1.0. (See accompanying\n//  file LICENSE_1_0.txt or copy at http://www.boost.org/LICENSE_1_0.txt)\n////////////////////////////////////////////////////////////////////////////////\n\n#if !defined(ASTM_DBA88345_57B8_4CC8_A574_D5F007250E95)\n#define ASTM_DBA88345_57B8_4CC8_A574_D5F007250E95\n\n// Legion runtime (default mapper assumed by the build/run environment).\n#include "legion.h"\n\n#include <cassert>\n#include <functional>\n#include <future>\n#include <mutex>\n#include <type_traits>\n#include <utility>\n\nnamespace astm { namespace detail {\n\n// A small future wrapper that provides .then(...) semantics expected by ASTM.\n// This keeps the existing ASTM interface intact while targeting Legion builds.\ntemplate <typename T>\nclass legion_future\n{\npublic:\n    legion_future() = default;\n\n    explicit legion_future(std::future<T>&& f)\n      : fut_(f.share())\n    {}\n\n    explicit legion_future(std::shared_future<T> f)\n      : fut_(std::move(f))\n    {}\n\n    T get() const\n    {\n        return fut_.get();\n    }\n\n    void wait() const\n    {\n        fut_.wait();\n    }\n\n    bool valid() const\n    {\n        return fut_.valid();\n    }\n\n    template <typename F>\n    auto then(F&& f) const\n      -> legion_future<typename std::invoke_result_t<std::decay_t<F>>>\n    {\n        using R = typename std::invoke_result_t<std::decay_t<F>>;\n        auto prev = fut_;\n\n        auto cont = std::async(std::launch::async,\n            [prev, fn = std::forward<F>(f)]() mutable -> R\n            {\n                prev.wait();\n                (void) prev.get(); // propagate exceptions from predecessor\n                if constexpr (std::is_void<R>::value)\n                {\n                    std::invoke(fn);\n                    return;\n                }\n                else\n                {\n                    return std::invoke(fn);\n                }\n            });\n\n        return legion_future<R>(std::move(cont));\n    }\n\nprivate:\n    std::shared_future<T> fut_;\n};\n\ntemplate <>\nclass legion_future<void>\n{\npublic:\n    legion_future() = default;\n\n    explicit legion_future(std::future<void>&& f)\n      : fut_(f.share())\n    {}\n\n    explicit legion_future(std::shared_future<void> f)\n      : fut_(std::move(f))\n    {}\n\n    void get() const\n    {\n        fut_.get();\n    }\n\n    void wait() const\n    {\n        fut_.wait();\n    }\n\n    bool valid() const\n    {\n        return fut_.valid();\n    }\n\n    template <typename F>\n    auto then(F&& f) const\n      -> legion_future<typename std::invoke_result_t<std::decay_t<F>>>\n    {\n        using R = typename std::invoke_result_t<std::decay_t<F>>;\n        auto prev = fut_;\n\n        auto cont = std::async(std::launch::async,\n            [prev, fn = std::forward<F>(f)]() mutable -> R\n            {\n                prev.wait();\n                prev.get(); // propagate exceptions from predecessor\n                if constexpr (std::is_void<R>::value)\n                {\n                    std::invoke(fn);\n                    return;\n                }\n                else\n                {\n                    return std::invoke(fn);\n                }\n            });\n\n        return legion_future<R>(std::move(cont));\n    }\n\nprivate:\n    std::shared_future<void> fut_;\n};\n\ntemplate <typename F, typename... Args>\nauto async(F&& f, Args&&... args)\n  -> legion_future<typename std::invoke_result_t<F, Args...>>\n{\n    using R = typename std::invoke_result_t<F, Args...>;\n    auto sf = std::async(std::launch::async,\n                         std::forward<F>(f),\n                         std::forward<Args>(args)...);\n    return legion_future<R>(std::move(sf));\n}\n\ninline legion_future<void> make_ready_future()\n{\n    std::promise<void> p;\n    p.set_value();\n    return legion_future<void>(p.get_future());\n}\n\ntemplate <typename T>\nlegion_future<typename std::decay<T>::type> make_ready_future(T&& value)\n{\n    using U = typename std::decay<T>::type;\n    std::promise<U> p;\n    p.set_value(std::forward<T>(value));\n    return legion_future<U>(p.get_future());\n}\n\n}} // namespace astm::detail\n\n// ASTM compatibility macros\n#define ASTM_MUTEX std::mutex\n#define ASTM_LOCK std::unique_lock<ASTM_MUTEX>\n#define ASTM_FUTURE astm::detail::legion_future\n#define ASTM_FUNCTION std::function\n#define ASTM_ASYNC astm::detail::async\n#define ASTM_MAKE_READY_FUTURE astm::detail::make_ready_future\n\n#define ASTM_TEST assert\n#define ASTM_REPORT 0\n\n#endif // ASTM_DBA88345_57B8_4CC8_A574_D5F007250E95\n', 'binary_tree.cpp': '////////////////////////////////////////////////////////////////////////////////\n//  Copyright (c) 2014 Bryce Adelstein-Lelbach\n//  Copyright (c) 2014 Steve Brandt\n//\n//  Distributed under the Boost Software License, Version 1.0. (See accompanying\n//  file LICENSE_1_0.txt or copy at http://www.boost.org/LICENSE_1_0.txt)\n////////////////////////////////////////////////////////////////////////////////\n\n#include <iostream>\n#include <fstream>\n#include <cstdint>\n#include <cstdlib>\n#include <string>\n#include <vector>\n\n#include "legion.h"\n#include "astm.hpp"\n\nusing namespace Legion;\nusing namespace astm;\n\nenum TaskIDs\n{\n    TOP_LEVEL_TASK_ID = 1\n};\n\ntemplate <typename Key, typename Value>\nstruct binary_tree\n{\n    struct node\n    {\n        shared_var<Key> key;\n        Value value;\n        shared_var<node*> left;\n        shared_var<node*> right;\n\n        node()\n          : key(), value(), left(), right()\n        {}\n\n        node(Key k, Value const& v, node* l, node* r)\n          : key(k), value(v), left(l), right(r)\n        {}\n\n        node(Key k, Value const& v, shared_var<node*> l, shared_var<node*> r)\n          : key(k), value(v), left(l), right(r)\n        {}\n\n        node(Key k, Value const& v)\n          : key(k), value(v), left(), right()\n        {}\n    };\n\n    binary_tree()\n      : root()\n    {}\n\n    void insert(Key key, Value const& value)\n    {\n        transaction t;\n        do {\n            auto root_ = root.get_local(t);\n\n            if (root_.get() != nullptr)\n                insert(key, value, root, t);\n            else\n                root_ = new node(key, value);\n        } while (!t.commit_transaction());\n    }\n\n    node* search(Key key)\n    {\n        node* n = nullptr;\n\n        transaction t;\n        do {\n            n = search(key, root, t);\n        } while (!t.commit_transaction());\n\n        return n;\n    }\n\n  private:\n    void insert(Key key, Value const& value, shared_var<node*>& leaf, transaction& t)\n    {\n        auto leaf_ = leaf.get_local(t);\n\n        if (key < leaf_.get()->key.get_local(t).get())\n        {\n            if (leaf_.get()->left.get_local(t).get() != nullptr)\n                insert(key, value, leaf_.get()->left, t);\n            else\n                leaf_.get()->left.get_local(t) = new node(key, value);\n        }\n        else // key >= current key\n        {\n            if (leaf_.get()->right.get_local(t).get() != nullptr)\n                insert(key, value, leaf_.get()->right, t);\n            else\n                leaf_.get()->right.get_local(t) = new node(key, value);\n        }\n    }\n\n    node* search(Key key, shared_var<node*>& leaf, transaction& t)\n    {\n        auto leaf_ = leaf.get_local(t);\n\n        if (leaf_.get() != nullptr)\n        {\n            if (key == leaf_.get()->key.get_local(t).get())\n                return leaf_.get();\n            if (key < leaf_.get()->key.get_local(t).get())\n                return search(key, leaf_.get()->left, t);\n            else\n                return search(key, leaf_.get()->right, t);\n        }\n\n        return nullptr;\n    }\n\n    shared_var<node*> root;\n};\n\nstatic void run_binary_tree_demo()\n{\n    std::ofstream outfile("binary_tree.txt");\n    if (!outfile.is_open()) {\n        std::cerr << "Failed to open binary_tree.txt for writing." << std::endl;\n        std::exit(1);\n    }\n\n    binary_tree<int, std::string> tree;\n\n    struct DataEntry {\n        int id;\n        std::string val;\n    };\n\n    std::vector<DataEntry> data = {\n        {50, "Root Node"},\n        {30, "Left Child"},\n        {70, "Right Child"},\n        {20, "Left-Left Grandchild"},\n        {40, "Left-Right Grandchild"},\n        {60, "Right-Left Grandchild"},\n        {80, "Right-Right Grandchild"}\n    };\n\n    outfile << "Inserting Data:\\n";\n    for (const auto& entry : data) {\n        outfile << "  Insert(Key: " << entry.id\n                << ", Value: \\"" << entry.val << "\\")" << std::endl;\n        tree.insert(entry.id, entry.val);\n    }\n    outfile << "\\n";\n\n    outfile << "Running Search Tests:\\n";\n    auto perform_search = [&](int search_key) {\n        outfile << "  Search(Key: " << search_key << ") -> ";\n        auto n = tree.search(search_key);\n\n        if (n != nullptr)\n            outfile << "Found! Result Value: \\"" << n->value << "\\"\\n";\n        else\n            outfile << "Not Found.\\n";\n    };\n\n    perform_search(99);\n    perform_search(10);\n    perform_search(50);\n    perform_search(20);\n    perform_search(60);\n    perform_search(80);\n    perform_search(45);\n\n    outfile.close();\n}\n\nvoid top_level_task(const Task* task,\n                    const std::vector<PhysicalRegion>& regions,\n                    Context ctx,\n                    Runtime* runtime)\n{\n    (void)task;\n    (void)regions;\n\n    astm::legion_context_scope scope(runtime, ctx);\n    run_binary_tree_demo();\n}\n\nint main(int argc, char** argv)\n{\n    Runtime::set_top_level_task_id(TOP_LEVEL_TASK_ID);\n\n    TaskVariantRegistrar registrar(TOP_LEVEL_TASK_ID, "top_level_task");\n    registrar.add_constraint(ProcessorConstraint(Processor::LOC_PROC));\n    Runtime::preregister_task_variant<top_level_task>(registrar, "top_level_task");\n\n    return Runtime::start(argc, argv);\n}\n', 'concurrency_tests.cpp': '#include "legion.h"\n\n#include <fstream>\n#include <iostream>\n#include <vector>\n\nusing namespace Legion;\n\nenum TaskIDs\n{\n  TOP_LEVEL_TASK_ID = 1,\n  INIT_TASK_ID,\n  INCREMENT_TASK_ID,\n  SQUARE_TASK_ID,\n  READ_TASK_ID\n};\n\nenum FieldIDs\n{\n  FID_VALUE = 1\n};\n\nstatic Future launch_init(Runtime* runtime, Context ctx, LogicalRegion lr, int value)\n{\n  TaskLauncher launcher(INIT_TASK_ID, TaskArgument(&value, sizeof(value)));\n  launcher.add_region_requirement(\n      RegionRequirement(lr, WRITE_DISCARD, EXCLUSIVE, lr));\n  launcher.region_requirements[0].add_field(FID_VALUE);\n  return runtime->execute_task(ctx, launcher);\n}\n\nstatic Future launch_increment(Runtime* runtime, Context ctx, LogicalRegion lr)\n{\n  TaskLauncher launcher(INCREMENT_TASK_ID, TaskArgument(nullptr, 0));\n  launcher.add_region_requirement(\n      RegionRequirement(lr, READ_WRITE, EXCLUSIVE, lr));\n  launcher.region_requirements[0].add_field(FID_VALUE);\n  return runtime->execute_task(ctx, launcher);\n}\n\nstatic Future launch_square(Runtime* runtime, Context ctx, LogicalRegion lr)\n{\n  TaskLauncher launcher(SQUARE_TASK_ID, TaskArgument(nullptr, 0));\n  launcher.add_region_requirement(\n      RegionRequirement(lr, READ_WRITE, EXCLUSIVE, lr));\n  launcher.region_requirements[0].add_field(FID_VALUE);\n  return runtime->execute_task(ctx, launcher);\n}\n\nstatic Future launch_read(Runtime* runtime, Context ctx, LogicalRegion lr)\n{\n  TaskLauncher launcher(READ_TASK_ID, TaskArgument(nullptr, 0));\n  launcher.add_region_requirement(\n      RegionRequirement(lr, READ_ONLY, EXCLUSIVE, lr));\n  launcher.region_requirements[0].add_field(FID_VALUE);\n  return runtime->execute_task(ctx, launcher);\n}\n\nvoid init_task(const Task* task,\n               const std::vector<PhysicalRegion>& regions,\n               Context,\n               Runtime*)\n{\n  const int init_value = *reinterpret_cast<const int*>(task->args);\n  FieldAccessor<WRITE_DISCARD, int, 1> acc(regions[0], FID_VALUE);\n  acc[Point<1>(0)] = init_value;\n}\n\nvoid increment_task(const Task*,\n                    const std::vector<PhysicalRegion>& regions,\n                    Context,\n                    Runtime*)\n{\n  FieldAccessor<READ_WRITE, int, 1> acc(regions[0], FID_VALUE);\n  const Point<1> p(0);\n  acc[p] = acc[p] + 1;\n}\n\nvoid square_task(const Task*,\n                 const std::vector<PhysicalRegion>& regions,\n                 Context,\n                 Runtime*)\n{\n  FieldAccessor<READ_WRITE, int, 1> acc(regions[0], FID_VALUE);\n  const Point<1> p(0);\n  acc[p] = acc[p] * acc[p];\n}\n\nint read_task(const Task*,\n              const std::vector<PhysicalRegion>& regions,\n              Context,\n              Runtime*)\n{\n  FieldAccessor<READ_ONLY, int, 1> acc(regions[0], FID_VALUE);\n  return acc[Point<1>(0)];\n}\n\nvoid top_level_task(const Task*,\n                    const std::vector<PhysicalRegion>&,\n                    Context ctx,\n                    Runtime* runtime)\n{\n  std::ofstream outfile("concurrency_tests.txt");\n  if (!outfile.is_open())\n  {\n    std::cerr << "Failed to open concurrency_tests.txt" << std::endl;\n    return;\n  }\n\n  // Create a single-element logical region holding one int field.\n  Rect<1> elem_rect(0, 0);\n  IndexSpace is = runtime->create_index_space(ctx, elem_rect);\n  FieldSpace fs = runtime->create_field_space(ctx);\n  {\n    FieldAllocator allocator = runtime->create_field_allocator(ctx, fs);\n    allocator.allocate_field(sizeof(int), FID_VALUE);\n  }\n  LogicalRegion lr = runtime->create_logical_region(ctx, is, fs);\n\n  // ---------------------------------------------------------\n  // TEST 1: High Concurrency Increment\n  // ---------------------------------------------------------\n  {\n    outfile << "Concurrency Increment Test\\n";\n    outfile << "  Initial Value: 0\\n";\n    outfile << "  Threads: 64\\n";\n    outfile << "  Operation: A = A + 1\\n";\n\n    launch_init(runtime, ctx, lr, 0).get_void_result();\n\n    std::vector<Future> futures;\n    futures.reserve(64);\n    for (unsigned i = 0; i < 64; ++i)\n      futures.push_back(launch_increment(runtime, ctx, lr));\n\n    for (auto& f : futures)\n      f.get_void_result();\n\n    int result = launch_read(runtime, ctx, lr).get_result<int>();\n\n    outfile << "  Expected Result: 64\\n";\n    outfile << "  Actual Result:   " << result << "\\n";\n    outfile << "  Status: " << (result == 64 ? "PASS" : "FAIL") << "\\n\\n";\n  }\n\n  // ---------------------------------------------------------\n  // TEST 2: Exponential Growth (Squaring)\n  // ---------------------------------------------------------\n  {\n    outfile << "Exponential Growth (Squaring) Test\\n";\n    outfile << "  Initial Value: 2\\n";\n    outfile << "  Threads: 4\\n";\n    outfile << "  Operation: A = A * A\\n";\n\n    launch_init(runtime, ctx, lr, 2).get_void_result();\n\n    std::vector<Future> futures;\n    futures.reserve(4);\n    for (unsigned i = 0; i < 4; ++i)\n      futures.push_back(launch_square(runtime, ctx, lr));\n\n    for (auto& f : futures)\n      f.get_void_result();\n\n    int result = launch_read(runtime, ctx, lr).get_result<int>();\n\n    outfile << "  Expected Result: 65536\\n";\n    outfile << "  Actual Result:   " << result << "\\n";\n    outfile << "  Status: " << (result == 65536 ? "PASS" : "FAIL") << "\\n";\n  }\n\n  runtime->destroy_logical_region(ctx, lr);\n  runtime->destroy_field_space(ctx, fs);\n  runtime->destroy_index_space(ctx, is);\n}\n\nint main(int argc, char** argv)\n{\n  Runtime::set_top_level_task_id(TOP_LEVEL_TASK_ID);\n\n  {\n    TaskVariantRegistrar registrar(TOP_LEVEL_TASK_ID, "top_level_task");\n    registrar.add_constraint(ProcessorConstraint(Processor::LOC_PROC));\n    Runtime::preregister_task_variant<top_level_task>(registrar, "top_level_task");\n  }\n\n  {\n    TaskVariantRegistrar registrar(INIT_TASK_ID, "init_task");\n    registrar.add_constraint(ProcessorConstraint(Processor::LOC_PROC));\n    Runtime::preregister_task_variant<init_task>(registrar, "init_task");\n  }\n\n  {\n    TaskVariantRegistrar registrar(INCREMENT_TASK_ID, "increment_task");\n    registrar.add_constraint(ProcessorConstraint(Processor::LOC_PROC));\n    Runtime::preregister_task_variant<increment_task>(registrar, "increment_task");\n  }\n\n  {\n    TaskVariantRegistrar registrar(SQUARE_TASK_ID, "square_task");\n    registrar.add_constraint(ProcessorConstraint(Processor::LOC_PROC));\n    Runtime::preregister_task_variant<square_task>(registrar, "square_task");\n  }\n\n  {\n    TaskVariantRegistrar registrar(READ_TASK_ID, "read_task");\n    registrar.add_constraint(ProcessorConstraint(Processor::LOC_PROC));\n    Runtime::preregister_task_variant<int, read_task>(registrar, "read_task");\n  }\n\n  return Runtime::start(argc, argv);\n}\n', 'unit_tests.cpp': '////////////////////////////////////////////////////////////////////////////////\n//  Copyright (c) 2014 Bryce Adelstein-Lelbach\n//  Copyright (c) 2014 Steve Brandt\n//\n//  Distributed under the Boost Software License, Version 1.0. (See accompanying\n//  file LICENSE_1_0.txt or copy at http://www.boost.org/LICENSE_1_0.txt)\n////////////////////////////////////////////////////////////////////////////////\n\n#include <iostream>\n#include <fstream>\n\n#include "legion.h"\n#include "astm.hpp"\n\nusing namespace Legion;\nusing namespace astm;\n\nenum UnitTestTaskIDs\n{\n    UNIT_TESTS_TOP_LEVEL_TASK_ID = 1\n};\n\nstatic void unit_tests_top_level_task(\n    const Task*,\n    const std::vector<PhysicalRegion>&,\n    Context ctx,\n    Runtime* runtime)\n{\n    astm::legion_context_scope scope(runtime, ctx);\n\n    std::ofstream outfile("unit_tests.txt");\n    if (!outfile.is_open()) {\n        std::cerr << "Could not open unit_tests.txt" << std::endl;\n        return;\n    }\n\n    { // Read A, Write A\n        shared_var<int> A(1);\n        transaction t;\n        do {\n            auto A_ = A.get_local(t);\n            A_ = 2;\n        } while (!t.commit_transaction());\n\n        outfile << "Test (Read A, Write A): A = " << A.read() << std::endl;\n    }\n\n    { // Write A, Read A\n        shared_var<int> A(1);\n\n        transaction t;\n        do {\n            auto A_ = A.get_local(t);\n            A_ = 2;\n        } while (!t.commit_transaction());\n\n        outfile << "Test (Write A, Read A): A = " << A.read() << std::endl;\n    }\n\n    { // Write A, Write A\n        shared_var<int> A(1);\n\n        transaction t;\n        do {\n            auto A_ = A.get_local(t);\n            ASTM_TEST(A_ == 1);\n            ASTM_TEST(A_ == 1);\n        } while (!t.commit_transaction());\n\n        outfile << "Test (Write A, Write A): A = " << A.read() << std::endl;\n    }\n\n    { // Write A, Write A (overwrite)\n        shared_var<int> A(1);\n\n        transaction t;\n        do {\n            auto A_ = A.get_local(t);\n            A_ = 2;\n            A_ = 2;\n        } while (!t.commit_transaction());\n\n        outfile << "Test (Overwrite): A = " << A.read() << std::endl;\n    }\n\n    { // Read A, Write A, Read A\n        shared_var<int> A(1);\n\n        transaction t;\n        do {\n            auto A_ = A.get_local(t);\n            A_ = 2;\n        } while (!t.commit_transaction());\n\n        outfile << "Test (Read -> Write -> Read): A = " << A.read() << std::endl;\n    }\n\n    { // Write A, Read A, Write A\n        shared_var<int> A(1);\n\n        transaction t;\n        do {\n            auto A_ = A.get_local(t);\n            A_ = 2;\n            A_ = 2;\n        } while (!t.commit_transaction());\n\n        outfile << "Test (Write -> Read -> Write): A = " << A.read() << std::endl;\n    }\n\n    { // Basic arithmetic with local_vars.\n        shared_var<int> A(4);\n        shared_var<int> B(1);\n\n        // atomic { A = A*A - B; }\n        transaction t;\n        do {\n            auto A_ = A.get_local(t);\n            auto B_ = B.get_local(t);\n\n            A_ = A_ * A_ - B_;\n        } while (!t.commit_transaction());\n\n        outfile << "Test (Arithmetic): A = " << A.read() << ", B = " << B.read() << std::endl;\n    }\n\n    { // Read A to future.\n        shared_var<int> A(4);\n        shared_var<int> B(1);\n\n        transaction t;\n        transaction_future IO(t);\n\n        do {\n            auto A_ = A.get_local(t);\n            auto B_ = B.get_local(t);\n\n            A_ = A_ * A_;\n\n            IO.then(\n                [local_A = int(A_)](transaction*) { ASTM_TEST(local_A == 16); }\n            );\n\n            A_ = A_ - B_;\n        } while (!t.commit_transaction());\n\n        IO.get();\n        outfile << "Test (Read A to Future): A = " << A.read() << ", B = " << B.read() << std::endl;\n    }\n\n    {\n        shared_var<int> A(4);\n\n        // atomic { A = A*A; }\n        bool fail = true;\n        int attempt_count = 0;\n        transaction t;\n        do {\n            ++attempt_count;\n\n            auto A_ = A.get_local(t);\n            int tmp = A_ * A_;\n\n            if (fail) {\n                A.write(3);\n                fail = false;\n            }\n\n            A_ = tmp;\n        } while (!t.commit_transaction());\n\n        outfile << "Test (Retry Logic): A = " << A.read()\n                << ", Attempts = " << attempt_count << std::endl;\n    }\n\n    outfile.close();\n}\n\nint main(int argc, char** argv)\n{\n    Runtime::set_top_level_task_id(UNIT_TESTS_TOP_LEVEL_TASK_ID);\n\n    TaskVariantRegistrar registrar(UNIT_TESTS_TOP_LEVEL_TASK_ID, "unit_tests_top_level_task");\n    registrar.add_constraint(ProcessorConstraint(Processor::LOC_PROC));\n    Runtime::preregister_task_variant<unit_tests_top_level_task>(\n        registrar, "unit_tests_top_level_task");\n\n    return Runtime::start(argc, argv);\n}\n'}
