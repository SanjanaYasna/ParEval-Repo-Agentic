hpp>\n#include <boost/numeric/odeint/util/same_size.hpp>\n\n// Legion is used by the translated codebase for task-based execution.\n// This resize utility itself is host-side and synchronous.\n#include "legion.h"\n\nusing dvec = std::vector<double>;\nusing shared_vec = std::shared_ptr<dvec>;\nusing state_type = std::vector<shared_vec>;\n\nnamespace boost {\nnamespace numeric {\nnamespace odeint {\n\ntemplate <>\nstruct is_resizeable<state_type>\n{\n    typedef boost::true_type type;\n    static constexpr bool value = type::value;\n};\n\ntemplate <>\nstruct same_size_impl<state_type, state_type>\n{\n    static bool same_size(const state_type &x1, const state_type &x2)\n    {\n        return x1.size() == x2.size();\n    }\n};\n\ntemplate <>\nstruct resize_impl<state_type, state_type>\n{\n    static void resize(state_type &x1, const state_type &x2)\n    {\n        x1.resize(x2.size());\n\n        for (std::size_t i = 0; i < x2.size(); ++i)\n        {\n            if (x2[i])\n            {\n                x1[i] = std::make_shared<dvec>(x2[i]->size());\n            }\n            else\n            {\n                x1[i] = std::make_shared<dvec>();\n            }\n        }\n    }\n};\n\n} // namespace odeint\n} // namespace numeric\n} // namespace boost\n\n#endif // SHARED_RESIZE_HPP\n', 'system.hpp': '// Copyright 2013 Mario Mulansky\n// Translated to Legion execution model\n\n#ifndef SYSTEM_HPP\n#define SYSTEM_HPP\n\n#include <legion.h>\n\n#include <boost/math/special_functions/sign.hpp>\n\n#include <cassert>\n#include <cmath>\n#include <cstddef>\n#include <cstdint>\n#include <vector>\n\nconst double KAPPA = 3.5;\nconst double LAMBDA = 4.5;\n\nnamespace checked_math {\ninline double pow(double x, double y) {\n  if (x == 0.0) return 0.0;\n  using std::abs;\n  using std::pow;\n  return pow(abs(x), y);\n}\n}  // namespace checked_math\n\ninline double signed_pow(double x, double k) {\n  using boost::math::sign;\n  return checked_math::pow(x, k) * sign(x);\n}\n\ntypedef