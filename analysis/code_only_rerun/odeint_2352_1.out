{'CMakeLists.txt': 'cmake_minimum_required(VERSION 3.16 FATAL_ERROR)\nproject(osc_1d_legion CXX)\n\n# Respect environment-provided package roots.\nif(DEFINED ENV{Legion_DIR} AND NOT Legion_DIR)\n  set(Legion_DIR "$ENV{Legion_DIR}" CACHE PATH "Path to Legion CMake config directory")\nendif()\n\nif(DEFINED ENV{BOOST_ROOT} AND NOT BOOST_ROOT)\n  set(BOOST_ROOT "$ENV{BOOST_ROOT}" CACHE PATH "Path to Boost installation")\nendif()\n\nset(CMAKE_CXX_STANDARD 17)\nset(CMAKE_CXX_STANDARD_REQUIRED ON)\nset(CMAKE_CXX_EXTENSIONS OFF)\n\n# Optional: default to Release if not specified.\nif(NOT CMAKE_BUILD_TYPE)\n  set(CMAKE_BUILD_TYPE Release CACHE STRING "Build type" FORCE)\nendif()\n\nfind_package(Legion REQUIRED)\nfind_package(Boost REQUIRED COMPONENTS program_options serialization thread)\n\nadd_executable(odeint\n  odeint.cpp\n  shared_resize.hpp\n  algebra.hpp\n  shared_operations.hpp\n  system.hpp\n)\n\ntarget_compile_options(odeint PRIVATE -O3)\n\n# Boost\nif(TARGET Boost::program_options)\n  target_link_libraries(odeint PRIVATE\n    Boost::program_options\n    Boost::serialization\n    Boost::thread\n  )\nelse()\n  target_include_directories(odeint PRIVATE ${Boost_INCLUDE_DIRS})\n  target_link_libraries(odeint PRIVATE ${Boost_LIBRARIES})\nendif()\n\n# Legion (support common exported target/variable names)\nif(TARGET Legion::Legion)\n  target_link_libraries(odeint PRIVATE Legion::Legion)\nelseif(TARGET Legion::Runtime)\n  target_link_libraries(odeint PRIVATE Legion::Runtime)\nelseif(TARGET legion)\n  target_link_libraries(odeint PRIVATE legion)\nelseif(DEFINED Legion_LIBRARIES)\n  target_link_libraries(odeint PRIVATE ${Legion_LIBRARIES})\nelseif(DEFINED LEGION_LIBRARIES)\n  target_link_libraries(odeint PRIVATE ${LEGION_LIBRARIES})\nelse()\n  message(FATAL_ERROR "find_package(Legion) succeeded, but no known Legion target/library was found.")\nendif()\n\nif(DEFINED Legion_INCLUDE_DIRS)\n  target_include_directories(odeint PRIVATE ${Legion_INCLUDE_DIRS})\nelseif(DEFINED LEGION_INCLUDE_DIRS)\n  target_include_directories(odeint PRIVATE ${LEGION_INCLUDE_DIRS})\nendif()\n', 'ReadMe.md': '# Legion Oscillator Chain (ODEINT)\n\nThe program integrates a 1D nonlinear oscillator chain with:\n\n- On-site potential exponent: `KAPPA = 3.5`\n- Coupling exponent: `LAMBDA = 4.5`\n\nTime integration is performed using boost::numeric::odeint::symplectic_rkn_sb3a_mclachlan which is a stepper suitable for Hamiltonian systems. (https://www.boost.org/doc/libs/1_88_0/boost/numeric/odeint/stepper/symplectic_rkn_sb3a_mclachlan.hpp)\nAll energy calculation outputs are written to ```odeint.txt```. The compiled program executable should be called ```odeint```.\n\n### Prerequisites\n\n- Legion installed\n- A C++17-compliant C++ compiler (e.g. GCC, Clang) and beyond\n- Boost, which path is set as `BOOST_ROOT` and incorporated into `LD_LIBRARY_PATH`\n\n### Build\n\nRepository depends on Legion 25.06.0\n\nMake sure to set $LEGION_ROOT to Legion install directory \n', 'algebra.hpp': '// Copyright 2013 Mario Mulansky\n#ifndef SHARED_ALGEBRA_HPP\n#define SHARED_ALGEBRA_HPP\n\n#include <cstddef>\n#include <cassert>\n#include <legion.h>\n\n// Legion translation note:\n// In the HPX version, this algebra used dataflow/futures for per-block async\n// composition. In Legion, this algebra is meant to run inside a Legion task\n// on already-acquired data, so we apply the operation directly per block.\nstruct local_dataflow_algebra\n{\n    template <typename S, typename Op>\n    void for_each3(S &s1, const S &s2, const S &s3, Op op) const\n    {\n        assert(s1.size() == s2.size());\n        assert(s1.size() == s3.size());\n\n        const std::size_t N = s1.size();\n        for (std::size_t i = 0; i < N; ++i)\n        {\n            s1[i] = op(s1[i], s2[i], s3[i]);\n        }\n    }\n};\n\n#endif\n', 'odeint.cpp': '// Translated from HPX to Legion execution model (default mapper)\n//\n// This version keeps the same CLI behavior:\n//   ./odeint --N 2048 --dt 0.1\n// and also supports Legion runtime flags, e.g.:\n//   ./odeint --N 2048 --dt 0.1 -ll:cpu 8\n\n#include "legion.h"\n\n#include <boost/program_options.hpp>\n\n#include <cmath>\n#include <cstdint>\n#include <fstream>\n#include <iostream>\n#include <random>\n#include <vector>\n\nusing namespace Legion;\n\nnamespace {\n\nconstexpr double KAPPA  = 3.5;\nconstexpr double LAMBDA = 4.5;\n\nenum TaskIDs {\n  TOP_LEVEL_TASK_ID = 1,\n  COMPUTE_DPDT_TASK_ID,\n  UPDATE_P_HALF_TASK_ID,\n  UPDATE_Q_TASK_ID,\n  ENERGY_BLOCK_TASK_ID\n};\n\nenum FieldIDs {\n  FID_Q = 100,\n  FID_P,\n  FID_DPDT\n};\n\ninline double abs_pow(double x, double y) {\n  if (x == 0.0) return 0.0;\n  return std::pow(std::abs(x), y);\n}\n\ninline double signed_pow(double x, double y) {\n  if (x == 0.0) return 0.0;\n  return std::copysign(std::pow(std::abs(x), y), x);\n}\n\nvoid compute_dpdt_task(const Task*,\n                       const std::vector<PhysicalRegion>& regions,\n                       Context ctx,\n                       Runtime* runtime) {\n  // regions[0]: full Q (READ_ONLY)\n  // regions[1]: block DPDT (WRITE_DISCARD)\n  FieldAccessor<READ_ONLY, double, 1> q(regions[0], FID_Q);\n  FieldAccessor<WRITE_DISCARD, double, 1> dpdt(regions[1], FID_DPDT);\n\n  Rect<1> full_rect = runtime->get_index_space_domain(\n      ctx, regions[0].get_logical_region().get_index_space());\n  Rect<1> my_rect = runtime->get_index_space_domain(\n      ctx, regions[1].get_logical_region().get_index_space());\n\n  const coord_t lo = full_rect.lo[0];\n  const coord_t hi = full_rect.hi[0];\n\n  for (coord_t i = my_rect.lo[0]; i <= my_rect.hi[0]; ++i) {\n    const Point<1> pi(i);\n\n    const double qi = q[pi];\n    const double ql = (i == lo) ? 0.0 : q[Point<1>(i - 1)];\n    const double qr = (i == hi) ? 0.0 : q[Point<1>(i + 1)];\n\n    const double coupling_left  = signed_pow(ql - qi, LAMBDA - 1.0);\n    const double coupling_right = signed_pow(qi - qr, LAMBDA - 1.0);\n\n    dpdt[pi] = -signed_pow(qi, KAPPA - 1.0) + coupling_left - coupling_right;\n  }\n}\n\nvoid update_p_half_task(const Task* task,\n                        const std::vector<PhysicalRegion>& regions,\n                        Context ctx,\n                        Runtime* runtime) {\n  // regions[0]: block P (READ_WRITE)\n  // regions[1]: block DPDT (READ_ONLY)\n  const double half_dt = *reinterpret_cast<const double*>(task->args);\n\n  FieldAccessor<READ_WRITE, double, 1> p(regions[0], FID_P);\n  FieldAccessor<READ_ONLY, double, 1> dpdt(regions[1], FID_DPDT);\n\n  Rect<1> my_rect = runtime->get_index_space_domain(\n      ctx, regions[0].get_logical_region().get_index_space());\n\n  for (coord_t i = my_rect.lo[0]; i <= my_rect.hi[0]; ++i) {\n    const Point<1> pi(i);\n    p[pi] = p[pi] + half_dt * dpdt[pi];\n  }\n}\n\nvoid update_q_task(const Task* task,\n                   const std::vector<PhysicalRegion>& regions,\n                   Context ctx,\n                   Runtime* runtime) {\n  // regions[0]: block Q (READ_WRITE)\n  // regions[1]: block P (READ_ONLY)\n  const double dt = *reinterpret_cast<const double*>(task->args);\n\n  FieldAccessor<READ_WRITE, double, 1> q(regions[0], FID_Q);\n  FieldAccessor<READ_ONLY, double, 1> p(regions[1], FID_P);\n\n  Rect<1> my_rect = runtime->get_index_space_domain(\n      ctx, regions[0].get_logical_region().get_index_space());\n\n  for (coord_t i = my_rect.lo[0]; i <= my_rect.hi[0]; ++i) {\n    const Point<1> pi(i);\n    q[pi] = q[pi] + dt * p[pi];\n  }\n}\n\ndouble energy_block_task(const Task*,\n                         const std::vector<PhysicalRegion>& regions,\n                         Context ctx,\n                         Runtime* runtime) {\n  // regions[0]: full Q (READ_ONLY)\n  // regions[1]: block P (READ_ONLY)\n  FieldAccessor<READ_ONLY, double, 1> q(regions[0], FID_Q);\n  FieldAccessor<READ_ONLY, double, 1> p(regions[1], FID_P);\n\n  Rect<1> full_rect = runtime->get_index_space_domain(\n      ctx, regions[0].get_logical_region().get_index_space());\n  Rect<1> my_rect = runtime->get_index_space_domain(\n      ctx, regions[1].get_logical_region().get_index_space());\n\n  const coord_t lo = full_rect.lo[0];\n  const coord_t hi = full_rect.hi[0];\n\n  double e = 0.0;\n  for (coord_t i = my_rect.lo[0]; i <= my_rect.hi[0]; ++i) {\n    const Point<1> pi(i);\n    const double qi = q[pi];\n    const double pi_v = p[pi];\n\n    e += 0.5 * pi_v * pi_v;\n    e += abs_pow(qi, KAPPA) / KAPPA;\n\n    if (i == lo) {\n      e += 0.5 * abs_pow(qi, LAMBDA) / LAMBDA;\n    }\n    if (i < hi) {\n      const double qnext = q[Point<1>(i + 1)];\n      e += abs_pow(qi - qnext, LAMBDA) / LAMBDA;\n    }\n    if (i == hi) {\n      e += 0.5 * abs_pow(qi, LAMBDA) / LAMBDA;\n    }\n  }\n  return e;\n}\n\nvoid launch_compute_dpdt(Runtime* runtime, Context ctx,\n                         LogicalRegion lr, LogicalPartition lp,\n                         const Domain& color_dom) {\n  IndexLauncher launcher(COMPUTE_DPDT_TASK_ID, color_dom,\n                         TaskArgument(nullptr, 0), ArgumentMap());\n\n  launcher.add_region_requirement(\n      RegionRequirement(lr, READ_ONLY, EXCLUSIVE, lr));\n  launcher.region_requirements[0].add_field(FID_Q);\n\n  launcher.add_region_requirement(\n      RegionRequirement(lp, 0, WRITE_DISCARD, EXCLUSIVE, lr));\n  launcher.region_requirements[1].add_field(FID_DPDT);\n\n  runtime->execute_index_space(ctx, launcher);\n}\n\nvoid launch_update_p_half(Runtime* runtime, Context ctx,\n                          LogicalRegion lr, LogicalPartition lp,\n                          const Domain& color_dom, double half_dt) {\n  IndexLauncher launcher(UPDATE_P_HALF_TASK_ID, color_dom,\n                         TaskArgument(&half_dt, sizeof(double)), ArgumentMap());\n\n  launcher.add_region_requirement(\n      RegionRequirement(lp, 0, READ_WRITE, EXCLUSIVE, lr));\n  launcher.region_requirements[0].add_field(FID_P);\n\n  launcher.add_region_requirement(\n      RegionRequirement(lp, 0, READ_ONLY, EXCLUSIVE, lr));\n  launcher.region_requirements[1].add_field(FID_DPDT);\n\n  runtime->execute_index_space(ctx, launcher);\n}\n\nvoid launch_update_q(Runtime* runtime, Context ctx,\n                     LogicalRegion lr, LogicalPartition lp,\n                     const Domain& color_dom, double dt) {\n  IndexLauncher launcher(UPDATE_Q_TASK_ID, color_dom,\n                         TaskArgument(&dt, sizeof(double)), ArgumentMap());\n\n  launcher.add_region_requirement(\n      RegionRequirement(lp, 0, READ_WRITE, EXCLUSIVE, lr));\n  launcher.region_requirements[0].add_field(FID_Q);\n\n  launcher.add_region_requirement(\n      RegionRequirement(lp, 0, READ_ONLY, EXCLUSIVE, lr));\n  launcher.region_requirements[1].add_field(FID_P);\n\n  runtime->execute_index_space(ctx, launcher);\n}\n\ndouble compute_total_energy(Runtime* runtime, Context ctx,\n                            LogicalRegion lr, LogicalPartition lp,\n                            const Domain& color_dom) {\n  IndexLauncher launcher(ENERGY_BLOCK_TASK_ID, color_dom,\n                         TaskArgument(nullptr, 0), ArgumentMap());\n\n  launcher.add_region_requirement(\n      RegionRequirement(lr, READ_ONLY, EXCLUSIVE, lr));\n  launcher.region_requirements[0].add_field(FID_Q);\n\n  launcher.add_region_requirement(\n      RegionRequirement(lp, 0, READ_ONLY, EXCLUSIVE, lr));\n  launcher.region_requirements[1].add_field(FID_P);\n\n  FutureMap fm = runtime->execute_index_space(ctx, launcher);\n\n  double total = 0.0;\n  for (Domain::DomainPointIterator it(color_dom); it; it++) {\n    total += fm.get_result<double>(it.p);\n  }\n  return total;\n}\n\nvoid top_level_task(const Task*,\n                    const std::vector<PhysicalRegion>&,\n                    Context ctx,\n                    Runtime* runtime) {\n  // Parse CLI (allow unregistered so Legion runtime flags pass through).\n  const InputArgs& command_args = Runtime::get_input_args();\n\n  boost::program_options::options_description desc("Usage: odeint [options]");\n  desc.add_options()\n      ("N", boost::program_options::value<std::size_t>()->default_value(1024),\n       "Dimension (1024)")\n      ("G", boost::program_options::value<std::size_t>()->default_value(128),\n       "Block size (128)")\n      ("steps", boost::program_options::value<std::size_t>()->default_value(100),\n       "time steps (100)")\n      ("dt", boost::program_options::value<double>()->default_value(0.01),\n       "step size (0.01)")\n      ("help", "Print help");\n\n  boost::program_options::variables_map vm;\n  try {\n    auto parsed = boost::program_options::command_line_parser(\n                      command_args.argc, command_args.argv)\n                      .options(desc)\n                      .allow_unregistered()\n                      .run();\n    boost::program_options::store(parsed, vm);\n    boost::program_options::notify(vm);\n  } catch (const std::exception& e) {\n    std::cerr << "Argument parsing error: " << e.what() << "\\n";\n    return;\n  }\n\n  if (vm.count("help")) {\n    std::cout << desc << "\\n";\n    return;\n  }\n\n  const std::size_t N = vm["N"].as<std::size_t>();\n  const std::size_t G = vm["G"].as<std::size_t>();\n  const std::size_t steps = vm["steps"].as<std::size_t>();\n  const double dt = vm["dt"].as<double>();\n\n  if (N == 0 || G == 0) {\n    std::cerr << "N and G must be > 0.\\n";\n    return;\n  }\n  if (N % G != 0) {\n    std::cerr << "For this Legion translation, N must be divisible by G.\\n";\n    return;\n  }\n\n  const std::size_t M = N / G;\n\n  std::ofstream outfile("odeint.txt");\n  if (!outfile.is_open()) {\n    std::cerr << "Failed to open odeint.txt for writing.\\n";\n    return;\n  }\n\n  outfile << "Dimension: " << N\n          << ", number of elements per dataflow: " << G\n          << ", number of dataflow: " << M\n          << ", steps: " << steps\n          << ", dt: " << dt << "\\n";\n\n  // Create region: [0..N-1], fields Q, P, DPDT\n  Rect<1> elem_rect(0, static_cast<coord_t>(N - 1));\n  IndexSpace is = runtime->create_index_space(ctx, elem_rect);\n\n  FieldSpace fs = runtime->create_field_space(ctx);\n  {\n    FieldAllocator allocator = runtime->create_field_allocator(ctx, fs);\n    allocator.allocate_field(sizeof(double), FID_Q);\n    allocator.allocate_field(sizeof(double), FID_P);\n    allocator.allocate_field(sizeof(double), FID_DPDT);\n  }\n\n  LogicalRegion lr = runtime->create_logical_region(ctx, is, fs);\n\n  // Partition into M blocks of size G\n  Rect<1> color_rect(0, static_cast<coord_t>(M - 1));\n  IndexSpace color_is = runtime->create_index_space(ctx, color_rect);\n\n  Transform<1, 1> transform;\n  transform[0][0] = static_cast<coord_t>(G);\n  Rect<1> extent(0, static_cast<coord_t>(G - 1));\n\n  IndexPartition ip = runtime->create_partition_by_restriction(\n      ctx, is, color_is, transform, extent);\n  LogicalPartition lp = runtime->get_logical_partition(ctx, lr, ip);\n  Domain color_dom(color_rect);\n\n  // Initialize q=0, p=random(-1,1), deterministic seed=0\n  {\n    RegionRequirement req(lr, WRITE_DISCARD, EXCLUSIVE, lr);\n    req.add_field(FID_Q);\n    req.add_field(FID_P);\n    InlineLauncher init_launcher(req);\n\n    PhysicalRegion pr = runtime->map_region(ctx, init_launcher);\n    pr.wait_until_valid();\n\n    FieldAccessor<WRITE_DISCARD, double, 1> q(pr, FID_Q);\n    FieldAccessor<WRITE_DISCARD, double, 1> p(pr, FID_P);\n\n    std::mt19937 engine(0);\n    std::uniform_real_distribution<double> dist(-1.0, 1.0);\n\n    for (coord_t i = elem_rect.lo[0]; i <= elem_rect.hi[0]; ++i) {\n      Point<1> pt(i);\n      q[pt] = 0.0;\n      p[pt] = dist(engine);\n    }\n\n    runtime->unmap_region(ctx, pr);\n  }\n\n  const double e_init = compute_total_energy(runtime, ctx, lr, lp, color_dom);\n  outfile << "Initialization complete, energy: "\n          << static_cast<long long>(std::round(e_init)) << "\\n";\n\n  // Time integration (velocity-Verlet, block-parallel)\n  for (std::size_t s = 0; s < steps; ++s) {\n    launch_compute_dpdt(runtime, ctx, lr, lp, color_dom);\n    launch_update_p_half(runtime, ctx, lr, lp, color_dom, 0.5 * dt);\n    launch_update_q(runtime, ctx, lr, lp, color_dom, dt);\n    launch_compute_dpdt(runtime, ctx, lr, lp, color_dom);\n    launch_update_p_half(runtime, ctx, lr, lp, color_dom, 0.5 * dt);\n  }\n\n  const double e_final = compute_total_energy(runtime, ctx, lr, lp, color_dom);\n  outfile << "Integration complete, energy: "\n          << static_cast<long long>(std::round(e_final)) << "\\n";\n\n  // Cleanup\n  runtime->destroy_logical_region(ctx, lr);\n  runtime->destroy_field_space(ctx, fs);\n  runtime->destroy_index_partition(ctx, ip);\n  runtime->destroy_index_space(ctx, color_is);\n  runtime->destroy_index_space(ctx, is);\n}\n\n} // anonymous namespace\n\nint main(int argc, char** argv) {\n  Runtime::set_top_level_task_id(TOP_LEVEL_TASK_ID);\n\n  {\n    TaskVariantRegistrar registrar(TOP_LEVEL_TASK_ID, "top_level");\n    registrar.add_constraint(ProcessorConstraint(Processor::LOC_PROC));\n    Runtime::preregister_task_variant<top_level_task>(registrar, "top_level");\n  }\n  {\n    TaskVariantRegistrar registrar(COMPUTE_DPDT_TASK_ID, "compute_dpdt");\n    registrar.add_constraint(ProcessorConstraint(Processor::LOC_PROC));\n    registrar.set_leaf();\n    Runtime::preregister_task_variant<compute_dpdt_task>(registrar, "compute_dpdt");\n  }\n  {\n    TaskVariantRegistrar registrar(UPDATE_P_HALF_TASK_ID, "update_p_half");\n    registrar.add_constraint(ProcessorConstraint(Processor::LOC_PROC));\n    registrar.set_leaf();\n    Runtime::preregister_task_variant<update_p_half_task>(registrar, "update_p_half");\n  }\n  {\n    TaskVariantRegistrar registrar(UPDATE_Q_TASK_ID, "update_q");\n    registrar.add_constraint(ProcessorConstraint(Processor::LOC_PROC));\n    registrar.set_leaf();\n    Runtime::preregister_task_variant<update_q_task>(registrar, "update_q");\n  }\n  {\n    TaskVariantRegistrar registrar(ENERGY_BLOCK_TASK_ID, "energy_block");\n    registrar.add_constraint(ProcessorConstraint(Processor::LOC_PROC));\n    registrar.set_leaf();\n    Runtime::preregister_task_variant<double, energy_block_task>(registrar, "energy_block");\n  }\n\n  return Runtime::start(argc, argv);\n}\n', 'shared_operations.hpp': '// Copyright 2013 Mario Mulansky\n// Translated for Legion-based code path (no HPX dependencies required here)\n#ifndef SHARED_OPERATIONS_HPP\n#define SHARED_OPERATIONS_HPP\n\n#include <cstddef>\n#include <memory>\n#include <vector>\n\nusing dvec = std::vector<double>;\nusing shared_vec = std::shared_ptr<dvec>;\n\nstruct local_dataflow_shared_operations\n{\n    template <typename Fac1, typename Fac2 = Fac1>\n    struct scale_sum2\n    {\n        const Fac1 m_alpha1;\n        const Fac2 m_alpha2;\n\n        scale_sum2()\n            : m_alpha1(0), m_alpha2(0)\n        {\n        }\n\n        scale_sum2(Fac1 alpha1, Fac2 alpha2)\n            : m_alpha1(alpha1), m_alpha2(alpha2)\n        {\n        }\n\n        template <typename S1, typename S2, typename S3>\n        S1 operator()(S1 x1, const S2 x2, const S3 x3) const\n        {\n            const std::size_t n = x1->size();\n            for (std::size_t i = 0; i < n; ++i)\n            {\n                (*x1)[i] = m_alpha1 * (*x2)[i] + m_alpha2 * (*x3)[i];\n            }\n            return x1;\n        }\n    };\n};\n\n#endif\n', 'shared_resize.hpp': '// Copyright 2013 Mario Mulansky\n// Resizing functionality for odeint (Legion translation)\n#ifndef SHARED_RESIZE_HPP\n#define SHARED_RESIZE_HPP\n\n#include <cstddef>\n#include <memory>\n#include <vector>\n\n#include <boost/numeric/odeint/util/is_resizeable.hpp>\n#include <boost/numeric/odeint/util/resize.hpp>\n#include <boost/numeric/odeint/util/same_size.hpp>\n#include <boost/numeric/odeint/util/state_wrapper.hpp>\n\n// Legion version: use eager/local state storage (no HPX shared_future/dataflow).\ntypedef std::vector<double> dvec;\ntypedef std::shared_ptr<dvec> shared_vec;\ntypedef std::vector<shared_vec> state_type;\n\nnamespace boost {\nnamespace numeric {\nnamespace odeint {\n\ntemplate <>\nstruct is_resizeable<state_type> {\n    typedef boost::true_type type;\n    static const bool value = type::value;\n};\n\ntemplate <>\nstruct same_size_impl<state_type, state_type> {\n    static bool same_size(const state_type& x1, const state_type& x2) {\n        return x1.size() == x2.size();\n    }\n};\n\ntemplate <>\nstruct resize_impl<state_type, state_type> {\n    static void resize(state_type& x1, const state_type& x2) {\n        x1.resize(x2.size());\n        for (std::size_t i = 0; i < x2.size(); ++i) {\n            const std::size_t n = (x2[i] ? x2[i]->size() : 0);\n            x1[i] = std::make_shared<dvec>(n);\n        }\n    }\n};\n\n}  // namespace odeint\n}  // namespace numeric\n}  // namespace boost\n\n#endif\n', 'system.hpp': '// Copyright 2013 Mario Mulansky\n// Translated from HPX dataflow to Legion tasks\n\n#ifndef SYSTEM_HPP\n#define SYSTEM_HPP\n\n#include <legion.h>\n\n#include <cassert>\n#include <cmath>\n#include <cstddef>\n#include <vector>\n\nconst double KAPPA = 3.5;\nconst double LAMBDA = 4.5;\n\nnamespace checked_math {\ninline double pow(double x, double y) {\n  if (x == 0.0) return 0.0;\n  using std::abs;\n  using std::pow;\n  return pow(abs(x), y);\n}\n}  // namespace checked_math\n\ninline double signed_pow(double x, double k) {\n  const double s = (x > 0.0) ? 1.0 : ((x < 0.0) ? -1.0 : 0.0);\n  return checked_math::pow(x, k) * s;\n}\n\ntypedef std::vector<double> dvec;\n\n// -----------------------------------------------------------------------------\n// Legion state representation (1D field partitioned into equal-sized blocks)\n// -----------------------------------------------------------------------------\nstruct state_type {\n  Legion::Runtime* runtime{nullptr};\n  Legion::Context ctx{};\n\n  Legion::IndexSpace is;\n  Legion::FieldSpace fs;\n  Legion::LogicalRegion lr;\n\n  Legion::IndexSpace color_is;\n  Legion::IndexPartition ip_blocks;\n  Legion::LogicalPartition lp_blocks;\n\n  Legion::FieldID fid{1};\n\n  std::size_t N{0};  // global size\n  std::size_t G{0};  // block size\n  std::size_t M{0};  // number of blocks\n};\n\nenum : Legion::TaskID {\n  OSC_CHAIN_BLOCK_TASK_ID = 1001\n};\n\nstruct osc_chain_task_args {\n  Legion::coord_t N;\n};\n\ninline state_type make_state(Legion::Runtime* runtime,\n                             Legion::Context ctx,\n                             std::size_t N,\n                             std::size_t G,\n                             Legion::FieldID fid = 1) {\n  assert(runtime != nullptr);\n  assert(G > 0);\n  assert((N % G) == 0 && "N must be divisible by G");\n\n  state_type s;\n  s.runtime = runtime;\n  s.ctx = ctx;\n  s.N = N;\n  s.G = G;\n  s.M = N / G;\n  s.fid = fid;\n\n  s.is = runtime->create_index_space(\n      ctx, Legion::Rect<1>(0, static_cast<Legion::coord_t>(N - 1)));\n\n  s.fs = runtime->create_field_space(ctx);\n  {\n    Legion::FieldAllocator alloc = runtime->create_field_allocator(ctx, s.fs);\n    alloc.allocate_field(sizeof(double), s.fid);\n  }\n\n  s.lr = runtime->create_logical_region(ctx, s.is, s.fs);\n\n  s.color_is = runtime->create_index_space(\n      ctx, Legion::Rect<1>(0, static_cast<Legion::coord_t>(s.M - 1)));\n\n  Legion::Transform<1, 1> transform;\n  transform[0][0] = static_cast<Legion::coord_t>(G);\n  Legion::Rect<1> extent(0, static_cast<Legion::coord_t>(G - 1));\n\n  s.ip_blocks = runtime->create_partition_by_restriction(\n      ctx, s.is, s.color_is, transform, extent);\n\n  s.lp_blocks = runtime->get_logical_partition(ctx, s.lr, s.ip_blocks);\n\n  return s;\n}\n\ninline void destroy_state(state_type& s) {\n  if (!s.runtime) return;\n  s.runtime->destroy_logical_region(s.ctx, s.lr);\n  s.runtime->destroy_field_space(s.ctx, s.fs);\n  s.runtime->destroy_index_partition(s.ctx, s.ip_blocks);\n  s.runtime->destroy_index_space(s.ctx, s.color_is);\n  s.runtime->destroy_index_space(s.ctx, s.is);\n  s = state_type{};\n}\n\n// -----------------------------------------------------------------------------\n// Legion task: compute dpdt for one block\n// -----------------------------------------------------------------------------\ninline void osc_chain_block_task(const Legion::Task* task,\n                                 const std::vector<Legion::PhysicalRegion>& regions,\n                                 Legion::Context ctx,\n                                 Legion::Runtime* runtime) {\n  assert(task->arglen == sizeof(osc_chain_task_args));\n  const auto* args = static_cast<const osc_chain_task_args*>(task->args);\n  const Legion::coord_t N = args->N;\n\n  // regions[0] = full q (READ_ONLY)\n  // regions[1] = one dpdt block (WRITE_DISCARD)\n  Legion::FieldAccessor<Legion::READ_ONLY, double, 1> q_acc(regions[0], task->regions[0].instance_fields[0]);\n  Legion::FieldAccessor<Legion::WRITE_DISCARD, double, 1> dpdt_acc(regions[1], task->regions[1].instance_fields[0]);\n\n  const Legion::Rect<1> block_rect =\n      runtime->get_index_space_domain(ctx, task->regions[1].region.get_index_space());\n\n  for (Legion::coord_t i = block_rect.lo[0]; i <= block_rect.hi[0]; ++i) {\n    const double qi = q_acc[Legion::Point<1>(i)];\n\n    const double onsite = -signed_pow(qi, KAPPA - 1.0);\n\n    const double left_coupling =\n        (i == 0) ? -signed_pow(qi, LAMBDA - 1.0)\n                 : signed_pow(q_acc[Legion::Point<1>(i - 1)] - qi, LAMBDA - 1.0);\n\n    const double right_flux =\n        (i == (N - 1)) ? signed_pow(qi, LAMBDA - 1.0)\n                       : signed_pow(qi - q_acc[Legion::Point<1>(i + 1)], LAMBDA - 1.0);\n\n    dpdt_acc[Legion::Point<1>(i)] = onsite + left_coupling - right_flux;\n  }\n}\n\ninline void preregister_system_tasks() {\n  Legion::TaskVariantRegistrar registrar(OSC_CHAIN_BLOCK_TASK_ID, "osc_chain_block_task");\n  registrar.add_constraint(Legion::ProcessorConstraint(Legion::Processor::LOC_PROC));\n  Legion::Runtime::preregister_task_variant<osc_chain_block_task>(registrar, "osc_chain_block_task");\n}\n\n// -----------------------------------------------------------------------------\n// System evaluation (Legion equivalent of HPX dataflow graph)\n// -----------------------------------------------------------------------------\ninline void osc_chain(state_type& q, state_type& dpdt) {\n  assert(q.runtime == dpdt.runtime);\n  assert(q.ctx == dpdt.ctx);\n  assert(q.N == dpdt.N);\n  assert(q.M == dpdt.M);\n\n  osc_chain_task_args args{static_cast<Legion::coord_t>(q.N)};\n  Legion::IndexLauncher launcher(\n      OSC_CHAIN_BLOCK_TASK_ID,\n      Legion::Rect<1>(0, static_cast<Legion::coord_t>(q.M - 1)),\n      Legion::TaskArgument(&args, sizeof(args)),\n      Legion::ArgumentMap());\n\n  launcher.add_region_requirement(\n      Legion::RegionRequirement(q.lr, Legion::READ_ONLY, Legion::EXCLUSIVE, q.lr));\n  launcher.region_requirements.back().add_field(q.fid);\n\n  launcher.add_region_requirement(\n      Legion::RegionRequirement(dpdt.lp_blocks, 0, Legion::WRITE_DISCARD, Legion::EXCLUSIVE, dpdt.lr));\n  launcher.region_requirements.back().add_field(dpdt.fid);\n\n  (void)q.runtime->execute_index_space(q.ctx, launcher);  // async launch\n}\n\ninline void osc_chain_gb(state_type& q, state_type& dpdt) {\n  assert(q.runtime == dpdt.runtime);\n  assert(q.ctx == dpdt.ctx);\n  assert(q.N == dpdt.N);\n  assert(q.M == dpdt.M);\n\n  osc_chain_task_args args{static_cast<Legion::coord_t>(q.N)};\n  Legion::IndexLauncher launcher(\n      OSC_CHAIN_BLOCK_TASK_ID,\n      Legion::Rect<1>(0, static_cast<Legion::coord_t>(q.M - 1)),\n      Legion::TaskArgument(&args, sizeof(args)),\n      Legion::ArgumentMap());\n\n  launcher.add_region_requirement(\n      Legion::RegionRequirement(q.lr, Legion::READ_ONLY, Legion::EXCLUSIVE, q.lr));\n  launcher.region_requirements.back().add_field(q.fid);\n\n  launcher.add_region_requirement(\n      Legion::RegionRequirement(dpdt.lp_blocks, 0, Legion::WRITE_DISCARD, Legion::EXCLUSIVE, dpdt.lr));\n  launcher.region_requirements.back().add_field(dpdt.fid);\n\n  Legion::FutureMap fm = q.runtime->execute_index_space(q.ctx, launcher);\n  fm.wait_all_results();  // global barrier\n}\n\n// -----------------------------------------------------------------------------\n// Energy\n// -----------------------------------------------------------------------------\ninline double energy(const dvec& q, const dvec& p) {\n  using checked_math::pow;\n  using std::abs;\n  const std::size_t N = q.size();\n\n  double e = 0.5 * pow(abs(q[0]), LAMBDA) / LAMBDA;\n  for (std::size_t i = 0; i < N - 1; ++i) {\n    e += 0.5 * p[i] * p[i] + pow(q[i], KAPPA) / KAPPA\n       + pow(abs(q[i] - q[i + 1]), LAMBDA) / LAMBDA;\n  }\n  e += 0.5 * p[N - 1] * p[N - 1] + pow(q[N - 1], KAPPA) / KAPPA\n     + 0.5 * pow(abs(q[N - 1]), LAMBDA) / LAMBDA;\n  return e;\n}\n\ninline dvec materialize_state(const state_type& s) {\n  Legion::InlineLauncher launcher(\n      Legion::RegionRequirement(s.lr, Legion::READ_ONLY, Legion::EXCLUSIVE, s.lr));\n  launcher.requirement.add_field(s.fid);\n\n  Legion::PhysicalRegion pr = s.runtime->map_region(s.ctx, launcher);\n  pr.wait_until_valid();\n\n  Legion::FieldAccessor<Legion::READ_ONLY, double, 1> acc(pr, s.fid);\n  const Legion::Rect<1> rect =\n      s.runtime->get_index_space_domain(s.ctx, s.is);\n\n  dvec out;\n  out.reserve(s.N);\n  for (Legion::coord_t i = rect.lo[0]; i <= rect.hi[0]; ++i) {\n    out.push_back(acc[Legion::Point<1>(i)]);\n  }\n\n  s.runtime->unmap_region(s.ctx, pr);\n  return out;\n}\n\ninline double energy(const state_type& q_state, const state_type& p_state) {\n  dvec q = materialize_state(q_state);\n  dvec p = materialize_state(p_state);\n  return energy(q, p);\n}\n\n#endif\n'}
